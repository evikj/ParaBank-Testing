    {
      "name": "API-11 Get Transactions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Transaction history contains deposit\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    var depositTransaction = jsonData.find(tr => tr.amount === 100 && tr.description.includes(\"Deposit\"));\r",
              "    \r",
              "    pm.expect(depositTransaction).to.not.be.undefined;\r",
              "    pm.expect(depositTransaction.amount).to.eql(100.00);\r",
              "});\r",
              "\r",
              "pm.test(\"Side Effect Detection: Found unauthorized overdraft transaction\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    // Check for any transaction with an unusually high amount, which might indicate an unauthorized overdraft.\r",
              "    var bugTransaction = jsonData.find(tr => tr.amount === 9999999);\r",
              "    \r",
              "    if (bugTransaction) {\r",
              "        console.warn(\"Confirmed: Buggy transaction of 9M is recorded in DB!\");\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
